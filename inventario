<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventario Higuerillas</title>
    <!-- Bootstrap para que se vea bien en móvil -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f4f4; padding-bottom: 50px; }
        .header-app { background: #002060; color: white; padding: 15px; text-align: center; }
        .card { margin: 10px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .btn-check-custom { width: 100%; margin-bottom: 5px; }
        .resumen-amarillo { background: #ffff00; font-weight: bold; padding: 10px; border-radius: 5px; }
    </style>
</head>
<body>

<div class="header-app">
    <h5>FERRETERÍA HIGUERILLAS</h5>
    <small>Toma de Inventario - Folio: 2026100</small>
</div>

<div class="container">
    <!-- SECCIÓN 1: DATOS CABECERA -->
    <div class="card p-3">
        <h6>DATOS GENERALES</h6>
        <input type="text" class="form-control mb-2" placeholder="Responsable: Loreto Olivares">
        <select class="form-select mb-2">
            <option>Tienda: Maitencillo</option>
            <option>Tienda: Otra</option>
        </select>
        <input type="text" class="form-control" placeholder="Categoría: Sherwin Williams">
    </div>

    <!-- SECCIÓN 2: LECTOR / ENTRADA DE DATOS -->
    <div class="card p-3">
        <h6>CONTEO DE PRODUCTOS</h6>
        <div class="input-group mb-3">
            <input type="text" id="codigo" class="form-control" placeholder="Código o Escanear">
            <button class="btn btn-primary" type="button">🔍</button>
        </div>
        <div id="producto-info" class="mb-2 text-muted small">
            Esperando código...
        </div>
        <div class="row">
            <div class="col">
                <label>Físico</label>
                <input type="number" class="form-control" id="conteo">
            </div>
            <div class="col">
                <label>Sistema</label>
                <input type="number" class="form-control" id="sistema" readonly value="19">
            </div>
        </div>
        <button class="btn btn-success mt-3 w-100">AGREGAR A LA LISTA</button>
    </div>

    <!-- SECCIÓN 3: CHECKLIST (Tu tercera hoja) -->
    <div class="card p-3">
        <h6>AUDITORÍA / OBSERVACIONES</h6>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="check1">
            <label class="form-check-label">¿Productos exhibidos?</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="check2">
            <label class="form-check-label">¿Tienen precio?</label>
        </div>
        <textarea class="form-control mt-2" placeholder="Comentarios..."></textarea>
    </div>

    <!-- SECCIÓN 4: RESUMEN (Tu primera hoja) -->
    <div class="card p-3">
        <div class="resumen-amarillo text-center">
            MONTO TOTAL A INVENTARIO: $ 4,747,467
        </div>
        <div class="mt-2 small">
            Diferencia Unidades: 0 <br>
            Diferencia Dinero: $ 0
        </div>
    </div>

    <button class="btn btn-danger w-100 mt-3 p-3">FINALIZAR Y GUARDAR</button>
</div>

<script>
    // Aquí irá la lógica para calcular diferencias y guardar en Excel/Base de datos
</script>

</body>
</html>
